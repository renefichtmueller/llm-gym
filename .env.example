# Copy to .env and adjust. Every value also has a sane built-in default,
# so the gym runs with no .env at all. Nothing here is secret by design —
# do NOT put real tokens in a committed .env.

# --- Server ---
LLMGYM_HOST=127.0.0.1
LLMGYM_PORT=8000

# --- Ollama ---
# Where your local Ollama server listens.
LLMGYM_OLLAMA_HOST=http://localhost:11434

# --- Base models (small for weak GPUs, large for strong ones) ---
LLMGYM_BASE_MODEL_SMALL=qwen2.5:3b
LLMGYM_BASE_MODEL_LARGE=qwen2.5:14b

# --- Training pool ---
# Local folder that holds your JSONL training data (one folder per pool).
LLMGYM_POOL_ROOT=./data/pool

# --- Optional Git/Gitea remote for the pool ---
# Leave empty to keep the pool local-only. If set, the gym can commit & push
# the pool to this remote. Use any Git host (self-hosted Gitea, GitHub, ...).
LLMGYM_GIT_REMOTE=
LLMGYM_GIT_BRANCH=main

# --- Training backend: auto | mlx | peft ---
LLMGYM_BACKEND=auto

# --- Phone terminal (./run.sh terminal, docs/PHONE_TERMINAL.md) ---
# Access token for the web terminal. Empty = a fresh random token per run
# (printed at startup). Fixing it lets you bookmark the URL on the phone —
# but then it IS a real secret: set it in .env only, never commit it.
LLMGYM_TERM_TOKEN=
# Public hostname when the terminal is served through a TLS tunnel or reverse
# proxy (e.g. term.example.com via Cloudflare Tunnel, or laptop.tail1234.ts.net
# via `tailscale serve`). Prints the https:// URL + QR and accepts that Origin.
LLMGYM_TERM_DOMAIN=
# Cloudflare Access (Zero Trust) in front of the terminal. Set TEAM to your
# <team>.cloudflareaccess.com and AUD to the Access application's AUD tag; the
# terminal then verifies the Access SSO JWT on every request. ACCESS_ONLY=1
# lets Access be the sole gate (no token needed on the phone). See
# docs/FLEET_ACCESS.md.
LLMGYM_TERM_ACCESS_TEAM=
LLMGYM_TERM_ACCESS_AUD=
LLMGYM_TERM_ACCESS_ONLY=
